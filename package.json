{
  "name": "memora-cmd",
  "version": "1.0.13",
  "description": "Never forget a command again. Save the terminal commands you always forget, find them instantly by describing what they do.",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "memora": "./bin/memora.js"
  },
  "scripts": {
    "start": "node bin/memora.js"
  },
  "keywords": [
    "cli",
    "terminal",
    "productivity",
    "command-history",
    "cheatsheet",
    "developer-tools",
    "snippets"
  ],
  "author": "Mohammed Abdul Raqeeb (https://linkedin.com/in/md-abdul-raqeeb-b85a1922a)",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "clipboardy": "^5.3.1",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "inquirer": "^9.2.16",
    "koffi": "^3.1.1",
    "nanoid": "^5.0.6"
  },
  "overrides": {
    "sharp": "npm:object-assign@4.1.1"
  }
